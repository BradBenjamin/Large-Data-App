# .env - Environment Configuration for Docker Compose
# Copy this to .env and adjust values as needed
# This file is automatically loaded by docker-compose

# ============================================
# API (Backend) Configuration
# ============================================
API_PORT=8000
API_URL=http://api:8000
MODEL_PATH=/app/model/amazon_lgb_model.txt

# ============================================
# Streamlit (Frontend) Configuration
# ============================================
STREAMLIT_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# ============================================
# Python Runtime Configuration
# ============================================
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO

# ============================================
# Production Deployment (uncomment if needed)
# ============================================
# API_URL=https://api.yourdomain.com
# STREAMLIT_SERVER_SSL_CERTFILE=/path/to/cert.pem
# STREAMLIT_SERVER_SSL_KEYFILE=/path/to/key.pem
